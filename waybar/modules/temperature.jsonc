{
    "temperature": {
        "thermal-zone": 2,
        "hwmon-path": "/sys/class/hwmon/hwmon1/temp1_input",
        "critical-threshold": 80,
        "format-critical": " {temperatureC}°C",
        "format": " {temperatureC}°C",
        "warning-threshold": 70,   // Becomes #temperature.warning
        "critical-threshold": 85   // Becomes #temperature.critical
    }
}
