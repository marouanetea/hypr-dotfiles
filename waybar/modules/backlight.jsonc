{    
    "backlight": {
        "device": "intel_backlight", // Change this if your screen uses a different interface (e.g., amdgpu_bl0)
        "format": "{icon}  {percent}%",
        "format-icons": ["󰃞", "󰃝", "󰃟", "󰃠"],
        "on-scroll-up": "brightnessctl set 5%+",
        "on-scroll-down": "brightnessctl set 5%-",
        "min-length": 6
    }
}
